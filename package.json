{
	"name": "jajaco--asset-encoder",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:worker": "npm run build && wrangler dev",
		"dev:worker:remote": "npm run build && wrangler dev --remote",
		"build": "vite build",
		"preview": "vite preview",
		"d1:migrate:local": "wrangler d1 migrations apply DB --local",
		"d1:migrate:remote": "wrangler d1 migrations apply DB --remote",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"wrangler": "^4.99.0"
	},
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"@sanity/client": "^7.17.0"
	}
}
